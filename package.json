{
  "name": "swayam-sevak",
  "version": "0.1.0",
  "description": "Swayam-Sevak — a personal AI operating system that runs locally for a single user.",
  "private": true,
  "type": "module",
  "bin": {
    "swayam": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "swayam": "tsx src/cli/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed-config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=18.17"
  }
}
