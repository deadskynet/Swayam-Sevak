# --- Provider selection ---
# Which LLM provider to use: "anthropic" | "huggingface" | "echo"
# "echo" is the offline test provider — useful before keys are configured.
SWAYAM_PROVIDER=echo

# --- Anthropic ---
# Get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-latest

# --- Hugging Face Inference API ---
# Free tier: https://huggingface.co/settings/tokens
HF_TOKEN=
# Default chat model for HF (must support chat completions). Override per-request if needed.
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# --- Telegram (optional) ---
# Create a bot with @BotFather. Required only when running `swayam telegram start`.
TELEGRAM_BOT_TOKEN=
# Restrict the bot to a single Telegram user id (find yours via @userinfobot).
# This MUST be the numeric id (e.g. 123456789), not your @username.
TELEGRAM_ALLOWED_USER_ID=

# --- gogcli (Google integration) ---
# Path to the `gog` binary. Default: looks up in $PATH.
GOG_BIN=gog

# --- Misc ---
# Override the data directory if you want to keep state outside the repo.
SWAYAM_DATA_DIR=
